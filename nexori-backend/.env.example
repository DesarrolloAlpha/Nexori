# ==========================================
# NEXORI BACKEND - Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env al repositorio
# ==========================================

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# URL pública del servidor (usada para QR codes en producción)
SERVER_URL=https://tu-dominio.com

# ==========================================
# BASE DE DATOS - PostgreSQL
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DB_DATABASE=nexori_db

# ==========================================
# TYPEORM
# ADVERTENCIA: TYPEORM_SYNCHRONIZE=true en producción
# puede borrar o modificar tablas automáticamente.
# Usar migraciones en producción.
# ==========================================
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# ==========================================
# JWT - Autenticación
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==========================================
JWT_SECRET=CAMBIAR_POR_UN_SECRET_LARGO_Y_ALEATORIO
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# CORS
# En producción: orígenes separados por coma
# ==========================================
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3001

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==========================================
# WHATSAPP BUSINESS API - META
# ==========================================

# Versión de la Graph API (actualizar cuando Meta publique nuevas versiones)
WHATSAPP_API_VERSION=v25.0

# ID del número de teléfono REAL del WABA (NO el test number)
# Lo encuentras en: Meta for Developers → WhatsApp → Configuración de la API → Phone number ID
WHATSAPP_PHONE_NUMBER_ID=ID_REAL_DEL_NUMERO

# Token permanente de System User (nunca expira)
# Cómo generarlo: business.facebook.com → Config → Usuarios del sistema
#   → Nuevo usuario → Agregar app → Generar token → Permisos: whatsapp_business_messaging → Expiración: Nunca
WHATSAPP_ACCESS_TOKEN=TOKEN_PERMANENTE_DE_SYSTEM_USER

# ID de la cuenta de WhatsApp Business (WABA)
WHATSAPP_BUSINESS_ACCOUNT_ID=ID_DEL_WABA

# Webhook: string libre que debes copiar EXACTO en Meta for Developers → Webhooks → Token de verificación
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CAMBIAR_TOKEN_SECRETO_WEBHOOK

# App Secret: Meta → Tu App → Configuración básica → Clave secreta de la app
# Con esto se valida la firma HMAC-SHA256 de cada evento entrante (OBLIGATORIO en producción)
WHATSAPP_APP_SECRET=CLAVE_SECRETA_DE_TU_APP_META

# Plantilla aprobada en Meta (nombre exacto, sin espacios)
WHATSAPP_TEMPLATE_NAME=registr_qr

# Idioma aprobado de la plantilla (debe coincidir con el aprobado en Meta)
WHATSAPP_TEMPLATE_LANG=es

# Número de prueba para endpoints de test (formato E.164 sin '+')
# Solo en desarrollo — en producción se puede omitir
WHATSAPP_TEST_NUMBER=573000000000

# ==========================================
# ADMIN POR DEFECTO
# Se crea en el primer arranque si no existe admin@nexori.com
# ==========================================
ADMIN_DEFAULT_PASSWORD=CAMBIAR_PASSWORD_ADMIN_SEGURO

# ==========================================
# UPLOADS
# ==========================================
UPLOAD_TEMP_DIR=./temp_uploads
